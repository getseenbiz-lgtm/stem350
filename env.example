# STEM350 AI Agent — Environment Variables
# Copy this file to .env and fill in your real values
# On Railway, add these directly in the Variables tab (do NOT commit .env to git)

# ── Sendblue ──────────────────────────────────────────────
SENDBLUE_API_KEY=your_sendblue_api_key_here
SENDBLUE_API_SECRET=your_sendblue_api_secret_here

# ── Anthropic (Claude) ────────────────────────────────────
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ── Server ────────────────────────────────────────────────
PORT=3000
